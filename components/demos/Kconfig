        config DEMO_04
            bool "DEMO 4: Queue pipeline (sample->upload)"

        config DEMO_05
            bool "DEMO 5: Task Notification"

        config DEMO_06
            bool "DEMO 6: EventGroup gate (WIFI/MQTT mock)"

        config DEMO_07
            bool "DEMO 7: Priority inversion & inheritance (mutex)"

        config DEMO_08
            bool "DEMO 8: Software timer"

        config DEMO_09
            bool "DEMO 9: Diagnostics (task list/runtime)"

    endchoice

endmenu
